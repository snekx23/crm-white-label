# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp Cloud API (Meta) - opcional, configurado por tenant via UI
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-random-string

# Instagram DM via Meta Messenger Platform
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=change-me-random-string

# Automacoes - chave para proteger endpoint de processamento
CRON_SECRET=change-me-random-cron-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
